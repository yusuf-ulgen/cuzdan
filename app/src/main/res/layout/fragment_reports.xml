<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/layoutBackground">


    <!-- Top Bar with Logo and Eye Icon -->
    <!-- Top Bar with Icons -->
    <LinearLayout
        android:id="@+id/layout_top_icons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layout_sync_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_last_updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="19:30"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                tools:text="19:30" />

            <TextView
                android:id="@+id/text_offline_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="OFFLINE"
                android:textColor="@color/accent_red"
                android:textSize="10sp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_currency_switcher"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_circle"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_tl"
            app:tint="?attr/iconTint" />

        <ImageButton
            android:id="@+id/btn_privacy_toggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_circle"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_eye_on"
            app:tint="?attr/iconTint" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_top_icons">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Main Title -->
            <LinearLayout
                android:id="@+id/layout_main_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_header_dropdown"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/text_main_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_profit_loss"
                    android:textColor="?attr/textPrimary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Portfolio Switcher (Compact Pill) -->
            <LinearLayout
                android:id="@+id/layout_portfolio_picker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_pill_dark"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_main_header">

                <ImageView
                    android:id="@+id/btn_prev_portfolio"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="?attr/textPrimary" />

                <TextView
                    android:id="@+id/text_portfolio_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/total_portfolios"
                    android:textColor="?attr/textPrimary"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/btn_next_portfolio"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="?attr/textPrimary" />
            </LinearLayout>

            <!-- Total Amount Section -->
            <TextView
                android:id="@+id/text_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:textColor="?attr/textPrimary"
                android:textSize="42sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_portfolio_picker"
                tools:text="-60 TL" />


            <TextView
                android:id="@+id/text_total_change_perc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill_dark"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/accent_red"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/text_total_amount"
                app:layout_constraintStart_toEndOf="@id/text_total_amount"
                app:layout_constraintTop_toTopOf="@id/text_total_amount"
                tools:text="%0,1"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layout_daily_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_pill_dark"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text_total_amount">

                <TextView
                    android:id="@+id/text_daily_change_abs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_red"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="- 1.643" />

                <TextView
                    android:id="@+id/text_daily_change_perc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/accent_red"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="%103,8" />

                <ImageView
                    android:id="@+id/image_daily_change_arrow"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    app:tint="@color/accent_red" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/label_daily_change"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_daily_change" />

            <!-- Category List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_report_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/layout_daily_change"
                tools:listitem="@layout/item_report_category" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
