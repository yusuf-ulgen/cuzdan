<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface_glass_strong"
    app:cardCornerRadius="32dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider_color"

    app:strokeWidth="0dp">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/image_category_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="@+id/text_category_change_perc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/text_category_title"
            tools:src="@drawable/ic_cat_stock" />

        <TextView
            android:id="@+id/text_category_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurface"
            android:textSize="20sp"
            android:letterSpacing="-0.01"
            app:layout_constraintStart_toEndOf="@id/image_category_icon"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="BIST" />

        <TextView
            android:id="@+id/text_category_change_perc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green"
            android:textSize="13sp"
            android:fontFamily="sans-serif-bold"
            app:layout_constraintStart_toStartOf="@id/text_category_title"
            app:layout_constraintTop_toBottomOf="@id/text_category_title"
            tools:text="%2,5" />

        <TextView
            android:id="@+id/text_category_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"

            android:layout_marginEnd="12dp"
            app:layout_constraintEnd_toStartOf="@id/image_expand_arrow"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="₺45.250,00" />

        <TextView
            android:id="@+id/text_category_change_abs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"

            android:fontFamily="sans-serif-medium"
            app:layout_constraintEnd_toEndOf="@id/text_category_total"
            app:layout_constraintTop_toBottomOf="@id/text_category_total"
            tools:text="₺1.250" />

        <ImageView
            android:id="@+id/image_expand_arrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_left"
            android:rotation="270"
            app:layout_constraintBottom_toBottomOf="@+id/text_category_change_perc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_label" />

        <!-- Child Assets (Visible when expanded) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_child_assets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/text_category_change_perc"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
