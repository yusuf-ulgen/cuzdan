<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/cash_demand_deposit_desc"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/edit_principal"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_search_bar"
        android:hint="@string/cash_input_principal_try"
        android:inputType="numberDecimal"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?android:attr/textColorSecondary" />

    <EditText
        android:id="@+id/edit_annual_rate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_bar"
        android:hint="@string/cash_input_annual_net_rate_optional"
        android:inputType="numberDecimal"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?android:attr/textColorSecondary" />

    <EditText
        android:id="@+id/edit_stopaj_rate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_bar"
        android:hint="@string/cash_input_stopaj_rate_optional"
        android:inputType="numberDecimal"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?android:attr/textColorSecondary" />

    <EditText
        android:id="@+id/edit_start_date"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_bar"
        android:hint="@string/cash_input_start_date"
        android:inputType="text"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?android:attr/textColorSecondary" />

    <TextView
        android:id="@+id/text_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/cash_result_placeholder"
        android:textColor="?attr/colorOnSurface"
        android:textSize="14sp" />

</LinearLayout>

