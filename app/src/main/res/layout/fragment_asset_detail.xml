<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/layoutBackground">


    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_icon_circle"
        android:padding="12dp"
        android:src="@drawable/ic_chevron_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/iconTint" />


    <TextView
        android:id="@+id/text_title_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="Varlık Detayı"
        android:textColor="?attr/textPrimary"
        android:textSize="24sp"

        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Chart Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardBackgroundColor="?attr/surfaceGlass"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/surfaceGlassStrong"
                app:strokeWidth="1.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/text_current_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="₺0.00"
                        android:textColor="?attr/textPrimary"
                        android:textSize="28sp"

                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_price_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="+0.00%"
                        android:textColor="@color/accent_green"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="@id/text_current_price"
                        app:layout_constraintStart_toEndOf="@id/text_current_price"
                        app:layout_constraintTop_toTopOf="@id/text_current_price" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/priceChart"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="44dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/text_current_price" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/chartRangeToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:checkedButton="@+id/btnRange1W"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <Button
                            android:id="@+id/btnRange1W"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="7G"
                            android:textSize="10sp"
                            android:textColor="?attr/textPrimary"
                            app:strokeColor="?attr/surfaceGlassStrong" />


                        <Button
                            android:id="@+id/btnRange1M"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="1A"
                            android:textSize="10sp"
                            android:textColor="?attr/textPrimary"
                            app:strokeColor="?attr/surfaceGlassStrong" />


                        <Button
                            android:id="@+id/btnRange1Y"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="1Y"
                            android:textSize="10sp"
                            android:textColor="?attr/textPrimary"
                            app:strokeColor="?attr/surfaceGlassStrong" />


                    </com.google.android.material.button.MaterialButtonToggleGroup>


                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-black"
                android:text="Miktar ve Maliyet"
                android:textColor="?attr/textPrimary"
                android:textSize="20sp" />


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="?attr/surfaceGlass"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/surfaceGlassStrong"
                app:strokeWidth="1.5dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Miktar"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/textAmountLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Adet"
                            android:textColor="@color/accent_violet_light"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/editAmount"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_search_bar"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="?attr/textPrimary"
                        android:textColorHint="?attr/textSecondary" />


                    <LinearLayout
                        android:id="@+id/layoutCostContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Birim Maliyet (Opsiyonel)"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editCost"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_search_bar"
                            android:hint="0.00"
                            android:inputType="numberDecimal"
                            android:paddingHorizontal="16dp"
                            android:textColor="?attr/textPrimary"
                            android:textColorHint="?attr/textSecondary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="@color/accent_violet"
                android:fontFamily="sans-serif-black"
                android:text="KAYDET"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="30dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
