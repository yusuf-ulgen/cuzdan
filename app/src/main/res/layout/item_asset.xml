<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:layout_marginBottom="8dp">

    <!-- Icon background for consistency (hidden if needed) -->
    <View
        android:id="@+id/viewIconBg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/ivAssetIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_asset_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/viewIconBg"
        app:layout_constraintEnd_toEndOf="@id/viewIconBg"
        app:layout_constraintStart_toStartOf="@id/viewIconBg"
        app:layout_constraintTop_toTopOf="@id/viewIconBg"
        app:tint="?attr/colorOnSurface" />

    <!-- Top Left: Asset Name -->
    <TextView
        android:id="@+id/tvAssetName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="?attr/colorOnSurface"
        android:textSize="15sp"
        android:fontFamily="sans-serif-bold"
        app:layout_constraintStart_toEndOf="@id/viewIconBg"
        app:layout_constraintTop_toTopOf="@id/viewIconBg"
        app:layout_constraintEnd_toStartOf="@+id/tvAssetPrice"
        tools:text="A1 Capital" />

    <!-- Top Right: Total Value -->
    <TextView
        android:id="@+id/tvAssetPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorOnSurface"
        android:textSize="15sp"
        android:fontFamily="sans-serif-bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/viewIconBg"
        tools:text="₺2.230,50" />

    <!-- Bottom Left: P/L Percentage -->
    <TextView
        android:id="@+id/tvAssetChangePerc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toStartOf="@id/tvAssetName"
        app:layout_constraintTop_toBottomOf="@id/tvAssetName"
        tools:text="%+2,5" />

    <!-- Bottom Right: P/L Amount -->
    <TextView
        android:id="@+id/tvAssetChangeAbs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAssetPrice"
        tools:text="+₺55,50" />

    <!-- Hidden Symbol view (still needed for logic possibly) -->
    <TextView
        android:id="@+id/tvAssetSymbol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="A1CAP" />

</androidx.constraintlayout.widget.ConstraintLayout>

