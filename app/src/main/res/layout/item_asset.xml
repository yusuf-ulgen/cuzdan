<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="4dp"
    android:paddingVertical="8dp">

    <View
        android:id="@+id/viewIconBg"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_circle_accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivAssetIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_asset_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/viewIconBg"
        app:layout_constraintEnd_toEndOf="@id/viewIconBg"
        app:layout_constraintStart_toStartOf="@id/viewIconBg"
        app:layout_constraintTop_toTopOf="@id/viewIconBg"
        app:tint="?attr/iconTint" />


    <TextView
        android:id="@+id/tvAssetName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="?attr/textPrimary"
        android:textSize="14sp"

        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toStartOf="@+id/tvAssetChange"
        app:layout_constraintStart_toEndOf="@id/viewIconBg"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Brent Petrol" />

    <TextView
        android:id="@+id/tvAssetSymbol"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="?attr/textSecondary"
        android:textSize="11sp"

        app:layout_constraintEnd_toStartOf="@+id/tvAssetPrice"
        app:layout_constraintStart_toStartOf="@id/tvAssetName"
        app:layout_constraintTop_toBottomOf="@id/tvAssetName"
        tools:text="BRENT" />

    <TextView
        android:id="@+id/tvAssetChange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/textPrimary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="₺1.457,00" />

    <TextView
        android:id="@+id/tvAssetPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent_green"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAssetChange"
        tools:text="+₺294,00" />

</androidx.constraintlayout.widget.ConstraintLayout>

