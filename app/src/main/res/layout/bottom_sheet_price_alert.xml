<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/sheetBackground"
    android:padding="24dp">

    <View
        android:id="@+id/view_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="?attr/surfaceGlass"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-black"
        android:text="Fiyat Alarmı Kur"
        android:textColor="?attr/textPrimary"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_handle" />

    <TextView
        android:id="@+id/text_asset_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BTC/USDT"
        android:textColor="?attr/textSecondary"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_title" />

    <TextView
        android:id="@+id/text_current_price_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Güncel Fiyat"
        android:textColor="?attr/textSecondary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_asset_info" />

    <TextView
        android:id="@+id/text_current_price_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="₺0.00"
        android:textColor="?attr/accentColor"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_current_price_label" />

    <TextView
        android:id="@+id/text_target_price_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Hedef Fiyat"
        android:textColor="?attr/textSecondary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_current_price_value" />

    <EditText
        android:id="@+id/edit_target_price"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_search_bar"
        android:hint="0.00"
        android:inputType="numberDecimal"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/textPrimary"
        android:textColorHint="?attr/textSecondary"
        app:layout_constraintTop_toBottomOf="@id/text_target_price_label" />

    <TextView
        android:id="@+id/text_condition_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Alarm Koşulu"
        android:textColor="?attr/textSecondary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edit_target_price" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_condition"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        app:checkedButton="@+id/btn_above"
        app:layout_constraintTop_toBottomOf="@id/text_condition_label"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_above"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ÜSTÜNE ÇIKINCA"
            android:textSize="12sp"
            app:strokeColor="?attr/surfaceGlassStrong" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_below"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ALTINA DÜŞÜNCE"
            android:textSize="12sp"
            app:strokeColor="?attr/surfaceGlassStrong" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_alert"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/accent_violet"
        android:fontFamily="sans-serif-black"
        android:text="ALARM KUR"
        android:textColor="@color/white"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toggle_condition" />

</androidx.constraintlayout.widget.ConstraintLayout>
