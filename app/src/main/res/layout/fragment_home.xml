<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp"
        tools:context=".ui.home.HomeFragment">

        <!-- Custom Donut Chart (Placeholder with ProgressBar) -->
        <FrameLayout
            android:id="@+id/layout_donut_container"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                android:id="@+id/donut_chart_bg"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:progressDrawable="@drawable/bg_donut_chart" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_donut_center_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="%100"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/text_donut_center_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dağılım"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Portfolio Selector -->
        <LinearLayout
            android:id="@+id/layout_portfolio_selector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_pill_dark"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_donut_container">

            <ImageButton
                android:id="@+id/btn_prev_portfolio"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/text_portfolio_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Portföyler Toplamı"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btn_next_portfolio"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:rotation="180"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Total Balance Section -->
        <TextView
            android:id="@+id/text_total_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="***** TL"
            android:textColor="@color/white"
            android:textSize="36sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_portfolio_selector" />

        <ImageButton
            android:id="@+id/btn_privacy_toggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_eye_on"
            app:layout_constraintBottom_toBottomOf="@id/text_total_balance"
            app:layout_constraintStart_toEndOf="@id/text_total_balance"
            app:layout_constraintTop_toTopOf="@id/text_total_balance"
            app:tint="@color/text_secondary" />

        <!-- Daily Change Pill -->
        <LinearLayout
            android:id="@+id/layout_daily_change_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_pill_dark"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_total_balance">

            <TextView
                android:id="@+id/text_daily_change_abs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*****"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_daily_change_perc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill_dark"
                android:paddingHorizontal="6dp"
                android:text="*****"
                android:paddingVertical="2dp"
                android:textColor="@color/accent_green"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/image_daily_change_trending"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_profit_loss"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/label_daily_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="GÜNLÜK DEĞİŞİM"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_daily_change_pill" />

        <!-- Expandable Asset List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_wallet_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/label_daily_change" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>