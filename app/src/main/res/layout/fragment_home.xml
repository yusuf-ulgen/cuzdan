<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/layoutBackground"

    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp"
        tools:context=".ui.home.HomeFragment">

        <!-- Header Section -->
        <!-- Top Bar with Header and Icons -->
        <TextView
            android:id="@+id/text_wallet_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-black"
            android:text="@string/title_home"
            android:textColor="?attr/textPrimary"
            android:textSize="22sp"
            android:alpha="0.7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layout_top_icons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="@id/text_wallet_header"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/text_wallet_header">

            <ImageButton
                android:id="@+id/btn_currency_switcher"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_circle"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_tl"
                app:tint="?attr/iconTint" />

            <ImageButton
                android:id="@+id/btn_privacy_toggle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_icon_circle"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_eye_on"
                app:tint="?attr/iconTint" />

            <ImageButton
                android:id="@+id/btn_add_portfolio"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_icon_circle"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_add"
                app:tint="?attr/accentColor" />
        </LinearLayout>


        <!-- Donut Chart Centered Top -->
        <com.example.cuzdan.ui.home.DonutChartView
            android:id="@+id/donut_chart"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="24dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_wallet_header" />



        <!-- Portfolio Switcher Pill -->
        <LinearLayout
            android:id="@+id/layout_portfolio_selector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_pill_dark"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/donut_chart">

            <ImageView
                android:id="@+id/btn_prev_portfolio"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_chevron_left"
                app:tint="?attr/textPrimary" />

            <TextView
                android:id="@+id/text_portfolio_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:fontFamily="sans-serif-black"
                android:text="Portföyüm"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/btn_next_portfolio"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="?attr/textPrimary" />
        </LinearLayout>


        <!-- Total Balance Section -->
        <LinearLayout
            android:id="@+id/layout_balance_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_portfolio_selector">

            <TextView
                android:id="@+id/text_total_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:text="₺0,00"
                android:textColor="?attr/textPrimary"
                android:textSize="48sp" />

            <!-- Daily Change Section (Pill + Label) -->
            <LinearLayout
                android:id="@+id/layout_daily_change_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_pill_dark"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/text_daily_change_perc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+₺0,00 (%0,00)"
                    android:textColor="@color/accent_green"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/label_daily_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.5"
                android:fontFamily="sans-serif-black"
                android:text="GÜNLÜK DEĞİŞİM"
                android:textColor="?attr/textPrimary"
                android:textSize="11sp" />
        </LinearLayout>








        <!-- Expandable Asset List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_wallet_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/layout_balance_container" />



    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>