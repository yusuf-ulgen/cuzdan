<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Cuzdan" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_violet</item>
        <item name="colorPrimaryVariant">@color/accent_violet_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_violet_light</item>
        <item name="colorSecondaryVariant">@color/accent_violet</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Global attribute defaults to prevent inflation crashes -->
        <item name="surfaceGlass">@color/surface_glass</item>
        <item name="surfaceGlassStrong">@color/surface_glass_strong</item>
        <item name="textPrimary">@color/white</item>
        <item name="textSecondary">@color/text_secondary</item>
        <item name="accentColor">@color/accent_violet</item>
        <item name="accentGlow">@color/accent_violet_glow</item>
        <item name="iconTint">@color/white</item>
        <item name="divider_light">@color/divider_color</item>
        <item name="sheetBackground">@drawable/bg_bottom_sheet</item>
        <item name="layoutBackground">@drawable/bg_main_gradient</item>
        <item name="pill_red_bg">#33FF4081</item>
        <item name="pill_red_text">@color/accent_red</item>
        <item name="pill_green_bg">#3300FF88</item>
        <item name="pill_green_text">@color/accent_green</item>

        <!-- Material Components Dialog Themes -->
        <item name="bottomSheetDialogTheme">@style/CustomBottomSheetDialog</item>
        <item name="alertDialogTheme">@style/CustomDialogTheme</item>
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>

        <!-- Material Attributes -->
        <item name="colorSurface">@color/surface_card_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/surface_glass_strong</item>
        <item name="colorOutline">@color/divider_color</item>
        <item name="colorPrimaryContainer">@color/accent_violet_glow</item>
        <item name="colorError">@color/accent_red</item>
        <item name="colorErrorContainer">#33FF4081</item>
        <item name="android:colorBackground">@color/bg_dark_start</item>
        <item name="colorOnBackground">@color/white</item>
    </style>

    <style name="Theme.Cuzdan.Dark" parent="Theme.Cuzdan">
        <item name="android:statusBarColor">@color/bg_dark_start</item>
        <item name="android:windowBackground">@drawable/bg_main_gradient</item>
        <item name="layoutBackground">@drawable/bg_main_gradient</item>
        <item name="pill_red_bg">#33FF4081</item>
        <item name="pill_red_text">@color/accent_red</item>
        <item name="pill_green_bg">#3300FF88</item>
        <item name="pill_green_text">@color/accent_green</item>
    </style>

    <style name="Theme.Cuzdan.Light" parent="Theme.Cuzdan">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">#0369A1</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#BAE6FD</item>
        <item name="colorSecondaryVariant">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/text_primary_light</item>
        
        <item name="android:statusBarColor">@color/bg_light_start</item>
        <item name="android:windowBackground">@drawable/bg_main_gradient_light</item>
        <item name="layoutBackground">@drawable/bg_main_gradient_light</item>
        <item name="surfaceGlass">@color/surface_light_glass</item>
        <item name="surfaceGlassStrong">@color/surface_light_glass_strong</item>
        <item name="textPrimary">@color/text_primary_light</item>
        <item name="textSecondary">@color/text_secondary_light</item>
        <item name="accentColor">@color/accent_blue</item>
        <item name="accentGlow">@color/accent_blue_glow</item>
        <item name="iconTint">@color/accent_blue</item>
        <item name="divider_light">@color/divider_light</item>
        <item name="pill_red_bg">@color/pill_red_bg</item>
        <item name="pill_red_text">@color/pill_red_text</item>
        <item name="pill_green_bg">@color/pill_green_bg</item>
        <item name="pill_green_text">@color/pill_green_text</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="sheetBackground">@drawable/bg_bottom_sheet_light</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">true</item>

        <!-- Material Attributes Light -->
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="colorSurfaceVariant">@color/surface_light_glass_strong</item>
        <item name="colorOutline">@color/divider_light</item>
        <item name="colorPrimaryContainer">@color/accent_blue_glow</item>
        <item name="colorError">@color/pill_red_text</item>
        <item name="colorErrorContainer">@color/pill_red_bg</item>
        <item name="android:colorBackground">@color/bg_light_start</item>
        <item name="colorOnBackground">@color/text_primary_light</item>
    </style>

    <style name="CustomBottomSheetDialog" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
        <!-- These will now inherit correctly from the Activity theme when used in context -->
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="CustomDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_glass_dialog</item>
        <!-- Standard attributes will be picked up from the parent theme -->
    </style>
</resources>